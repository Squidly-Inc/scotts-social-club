---
const { transparent = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const path = Astro.url.pathname.replace(base, "") || "/";
const isActive = (p: string) => path === p || (p !== "/" && path.startsWith(p));
const url = (p: string) => `${base}${p}`;
---

<header
  class:list={[
    "fixed top-0 left-0 right-0 z-50 transition-all duration-300",
    transparent ? "bg-transparent" : "bg-teal-deep/95 backdrop-blur",
  ]}
  data-header
>
  <div class="max-w-7xl mx-auto px-5 sm:px-8 py-4 flex items-center justify-between">
    <a href={url("/")} class="block">
      <img src={url("/scotts-social-club.png")} alt="Scott's Social Club San Jose" class="h-12 sm:h-14 w-auto" />
    </a>

    <nav class="hidden lg:flex items-center gap-8 text-sm tracking-wider uppercase text-cream/90">
      <a href={url("/about")} class:list={["hover:text-gold-light transition", isActive("/about") && "text-gold-light"]}>About</a>
      <a href={url("/events")} class:list={["hover:text-gold-light transition", isActive("/events") && "text-gold-light"]}>Events</a>
      <a href={url("/membership")} class:list={["hover:text-gold-light transition", isActive("/membership") && "text-gold-light"]}>Membership</a>
      <a href={url("/contact")} class:list={["hover:text-gold-light transition", isActive("/contact") && "text-gold-light"]}>Contact</a>
    </nav>

    <a href={url("/membership") + "#join"} class="hidden lg:inline-block bg-gold text-teal-deep text-xs font-semibold uppercase tracking-widest px-5 py-2.5 hover:bg-cream transition">
      Join Now
    </a>

    <button data-mobile-toggle class="lg:hidden text-cream p-2" aria-label="Open menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
    </button>
  </div>

  <div data-mobile-menu class="hidden lg:hidden bg-teal-deep text-cream border-t border-cream/10">
    <nav class="flex flex-col px-5 py-6 gap-1 text-sm uppercase tracking-wider">
      <a href={url("/about")} class="py-3 border-b border-cream/10 hover:text-gold-light">About</a>
      <a href={url("/events")} class="py-3 border-b border-cream/10 hover:text-gold-light">Events</a>
      <a href={url("/membership")} class="py-3 border-b border-cream/10 hover:text-gold-light">Membership</a>
      <a href={url("/contact")} class="py-3 hover:text-gold-light">Contact</a>
      <a href={url("/membership") + "#join"} class="mt-4 bg-gold text-teal-deep text-center font-semibold py-3 hover:bg-cream transition">Join Now</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector("[data-mobile-toggle]");
  const menu = document.querySelector("[data-mobile-menu]");
  toggle?.addEventListener("click", () => menu?.classList.toggle("hidden"));

  const header = document.querySelector("[data-header]") as HTMLElement | null;
  if (header && header.classList.contains("bg-transparent")) {
    const onScroll = () => {
      if (window.scrollY > 60) {
        header.classList.remove("bg-transparent");
        header.classList.add("bg-teal-deep/95", "backdrop-blur");
      } else {
        header.classList.add("bg-transparent");
        header.classList.remove("bg-teal-deep/95", "backdrop-blur");
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
