---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact | Scott's Social Club">
  <section class="bg-teal-deep pt-32 pb-12 sm:pb-16">
    <div class="max-w-3xl mx-auto px-5 sm:px-8 text-center">
      <p class="text-gold-light uppercase tracking-[0.3em] text-xs mb-4">Get in Touch</p>
      <h1 class="font-display text-4xl sm:text-6xl text-cream mb-5 leading-tight">
        Your skyline awaits.
      </h1>
      <p class="text-cream/75 max-w-xl mx-auto leading-relaxed">
        Apply for membership, ask a question, or RSVP for an event.
      </p>
    </div>
  </section>

  <section class="bg-cream-soft py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 grid lg:grid-cols-5 gap-12 lg:gap-16">
      <div class="lg:col-span-2 space-y-10">
        <div>
          <h2 class="text-xs uppercase tracking-widest text-teal font-semibold mb-3">Address</h2>
          <p class="font-display text-2xl text-ink leading-snug">
            88 S. 4th Street, 7th Floor<br/>
            The Rotary Summit Center<br/>
            San Jose, CA 95112
          </p>
          <a href="https://maps.google.com/?q=88+S+4th+St+San+Jose+CA+95112" target="_blank" rel="noopener" class="inline-block mt-3 text-teal text-xs uppercase tracking-widest font-semibold border-b border-teal pb-1 hover:text-gold-deep">
            Get Directions →
          </a>
        </div>

        <div>
          <h2 class="text-xs uppercase tracking-widest text-teal font-semibold mb-3">Phone</h2>
          <a href="tel:+14084646992" class="font-display text-2xl text-ink hover:text-gold-deep transition">(408) 464-6992</a>
        </div>

        <div>
          <h2 class="text-xs uppercase tracking-widest text-teal font-semibold mb-3">Membership Inquiries</h2>
          <p class="text-ink mb-2">Robert Robledo</p>
          <a href="mailto:membership@scottssocialclub.com" class="block text-ink/80 hover:text-gold-deep transition">membership@scottssocialclub.com</a>
        </div>

        <div>
          <h2 class="text-xs uppercase tracking-widest text-teal font-semibold mb-3">Member Login</h2>
          <p class="text-ink/70 leading-relaxed mb-4 text-sm">
            Existing members can sign in to view the member directory, RSVP for events, and access partner discounts.
          </p>
          <a href="#" class="inline-block border border-teal text-teal text-xs font-semibold uppercase tracking-widest px-6 py-3 hover:bg-teal hover:text-cream transition">
            Member Login →
          </a>
        </div>
      </div>

      <div class="lg:col-span-3 aspect-[4/3] lg:aspect-auto lg:min-h-[600px] bg-ink/10 shadow-xl">
        <iframe
          src="https://maps.google.com/maps?q=88+S+4th+St,+San+Jose,+CA+95112&output=embed"
          class="w-full h-full"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Scott's Social Club Map"
        ></iframe>
      </div>
    </div>
  </section>

  <section class="bg-ink py-16 sm:py-20">
    <div class="max-w-2xl mx-auto px-5 sm:px-8 text-center">
      <p class="text-gold-light uppercase tracking-[0.3em] text-xs mb-3">Stay in the Loop</p>
      <h2 class="font-display text-2xl sm:text-3xl text-cream mb-3 leading-tight">
        Hear about upcoming events.
      </h2>
      <p class="text-cream/70 leading-relaxed mb-7 text-sm">
        Member-only previews, public-event invites, and the occasional update
        from the Club — in your inbox a few times a month.
      </p>
      <form data-newsletter-pending onsubmit="event.preventDefault(); this.reset(); var btn=this.querySelector('button'); if(btn) btn.textContent='Subscribed ✓'; this.classList.add('opacity-60','pointer-events-none');" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <label class="sr-only" for="newsletter-email">Email address</label>
        <input id="newsletter-email" name="email" type="email" required placeholder="you@example.com" class="flex-1 bg-cream-soft text-ink px-4 py-3 placeholder:text-ink/40 focus:outline-none focus:ring-2 focus:ring-gold-light" />
        <button type="submit" class="bg-gold-light text-ink text-xs font-semibold uppercase tracking-widest px-6 py-3 hover:bg-cream transition">Subscribe</button>
      </form>
      <p class="text-cream/60 text-xs mt-4">We respect your inbox. No spam, unsubscribe anytime.</p>
    </div>
  </section>
</Layout>
